# .env.example - Manajemen Resiko
# Salin ke .env.local (di-gitignore). JANGAN pernah commit .env.local.
# Semua nilai di bawah adalah CONTOH/placeholder — isi dengan nilai proyek Anda.

# ---------- PUBLIK (aman di client, dipagari RLS) ----------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-publik-jwt>
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ---------- RAHASIA (server-only; isi lokal, JANGAN pernah share/commit) ----------
# Ambil dari Supabase Dashboard > Project Settings > API / Database.
# Jika pernah terekspos: ROTATE.
SUPABASE_SERVICE_ROLE_KEY=ISI_LOKAL_JANGAN_COMMIT
SUPABASE_DB_PASSWORD=ISI_LOKAL_JANGAN_COMMIT

# ---------- CLI / migrasi (supabase link, db push, CI) ----------
# PROJECT_REF: ref proyek (Dashboard > Project Settings > General). Bukan rahasia.
SUPABASE_PROJECT_REF=<project-ref>
# ACCESS_TOKEN: token akun untuk Management API (supabase login/link) & CI.
# Server-only, rahasia. Buat di https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=ISI_LOKAL_JANGAN_COMMIT

# Email (Resend) - dibuat saat T-061
RESEND_API_KEY=ISI_LOKAL_JANGAN_COMMIT

# Monitoring (Sentry) - dibuat saat T-081
SENTRY_DSN=
SENTRY_AUTH_TOKEN=ISI_LOKAL_JANGAN_COMMIT
